rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    
    // Hardcoded Admin check for list queries (to avoid get() in list blocks)
    function isSystemAdmin() {
      return isSignedIn() && request.auth.token.email == 'tipsbet877@gmail.com';
    }

    // DB-backed Admin check for single document operations
    function isDBAdmin() { 
      return isSignedIn() && 
      exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
      get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // --- Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'balance', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.email is string &&
             data.role in ['user', 'admin'] &&
             data.balance is number &&
             data.balance >= 0;
    }

    function isValidAd(data) {
      return data.keys().hasAll(['ownerId', 'title', 'description', 'status', 'budget', 'createdAt', 'link', 'category', 'targeting', 'stats', 'spend', 'duration']) &&
             data.ownerId == request.auth.uid &&
             data.title is string && data.title.size() <= 150 &&
             data.description is string && data.description.size() <= 2000 &&
             data.status in ['pending', 'active', 'rejected', 'paused', 'expired'] &&
             data.budget is number && data.budget >= 0 &&
             data.stats is map &&
             data.targeting is map;
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'createdAt', 'status']) &&
             data.userId == request.auth.uid &&
             data.amount is number &&
             data.type in ['deposit', 'spend', 'refund'] &&
             data.status in ['completed', 'pending', 'failed'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.type in ['approval', 'rejection', 'payment', 'expiration', 'system'] &&
             data.read is bool;
    }

    // --- Rules ---
    match /users/{userId} {
      allow get: if isOwner(userId) || isDBAdmin();
      allow list: if isSystemAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && 
                    ( (incoming().role == 'user' && incoming().balance == 0) || (incoming().role == 'admin' && isSystemAdmin()) );
      allow update: if (isOwner(userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'balance'])
      )) || isDBAdmin();
    }

    match /ads/{adId} {
      allow get: if true;
      allow list: if (resource.data.status == 'active') || 
                    (isSignedIn() && resource.data.ownerId == request.auth.uid) || 
                    isSystemAdmin();
      allow create: if isSignedIn() && isValidAd(incoming()) && incoming().status == 'pending';
      allow update: if (
        (isOwner(existing().ownerId) && (
          incoming().diff(existing()).affectedKeys().hasAny(['title', 'description', 'status', 'category', 'targeting'])
        ))
      ) || (
        isDBAdmin() && incoming().diff(existing()).affectedKeys().hasAny(['status', 'rejectionReason', 'approvedAt'])
      );
      allow delete: if isDBAdmin();
    }

    match /transactions/{txId} {
      allow get: if isOwner(resource.data.userId) || isDBAdmin();
      allow list: if isOwner(resource.data.userId) || isSystemAdmin();
      allow create: if isSignedIn() && isValidTransaction(incoming());
    }

    match /notifications/{notifId} {
      allow get: if isOwner(resource.data.userId) || isDBAdmin();
      allow list: if isOwner(resource.data.userId) || isSystemAdmin();
      allow create: if isDBAdmin() || isSystemAdmin();
      allow update: if isOwner(existing().userId) && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
    
    match /categories/{catId} {
      allow read: if true;
      allow write: if isDBAdmin();
    }
  }
}
